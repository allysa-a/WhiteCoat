# Optional: explicit API base for frontend requests.
# Leave empty to use same-origin '/api' (works with Vite proxy in dev).
# If app is deployed in a subfolder (example: https://domain.com/deployment),
# set VITE_API_BASE_URL to that subfolder path (example: /deployment).
VITE_API_BASE_URL=

# Optional: explicit backend origin for upload URLs (img src/file links).
# Example: http://localhost:8000
VITE_BACKEND_BASE=http://localhost:8000

# Existing Vite proxy target in vite.config.ts can also be used:
# VITE_API_TARGET=http://localhost:8000
