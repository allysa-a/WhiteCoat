# Backend environment settings
APP_ENV=production
APP_DEBUG=false
JWT_SECRET=change-this-secret

# Database settings
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=
DB_NAME=whitecoat

# CORS origins (comma-separated). Use * only for local/testing.
# Example: CORS_ALLOW_ORIGIN=https://clinic.example.com,https://app.example.com
CORS_ALLOW_ORIGIN=*

# Optional external DOCX->PDF service integration
DOCX_TO_PDF_URL=
DOCX_TO_PDF_TOKEN=

# Optional frontend URL used for email verification redirects
FRONTEND_URL=http://localhost/deployment

# Google Form integration for notifications page.
# Set this to your Google Form responses source URL (recommended: Google Apps Script Web App JSON URL,
# Google Visualization JSON URL, or Google Sheets API values URL).
GOOGLE_FORM_RESPONSES_URL=https://docs.google.com/forms/d/1bZuhDpUMlvFtNxn1jUpCWvrx4DC9wMEIthklJCnzKto/edit#responses

